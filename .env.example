# Using booking@dummyticketverified.com (Hostinger mailbox)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=booking@dummyticketverified.com
SMTP_PASS=your-mailbox-password

# SendGrid example (alternative):
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your-sendgrid-api-key

# From address shown to customers
MAIL_FROM="Dummy Ticket Verified <booking@dummyticketverified.com>"

# New order alerts land here
MAIL_TO=booking@dummyticketverified.com

# Used for logo/airline images and footer links in emails
SITE_URL=https://dummyticketverified.com
# Local dev: SITE_URL=http://localhost:3000
WHATSAPP_NUMBER=+918800648490
